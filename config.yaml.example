# Obsidian Vault Semantic Index — config (cloud providers)
# Copy to config.yaml and set vault_root / index_root for your environment.
# API keys: use env vars (e.g. GEMINI_API_KEY), not this file.
#
# This config uses cloud APIs only — no local servers required.
# For local/self-hosted providers, see config.local.yaml.example.

vault_root: "/path/to/your/obsidian-vault"
index_root: "/path/to/index/output"

scan:
  # Supported file types: md, pdf, images (png/jpg/jpeg), audio/video, documents
  # (docx/doc/pptx/rtf/epub/html/htm/csv/txt), and spreadsheets (xlsx/xls).
  include:
    - "**/*.md"
    - "**/*.pdf"
    - "**/*.png"
    - "**/*.jpg"
    - "**/*.jpeg"
    - "**/*.docx"
    - "**/*.doc"
    - "**/*.pptx"
    - "**/*.rtf"
    - "**/*.epub"
    - "**/*.html"
    - "**/*.htm"
    - "**/*.csv"
    - "**/*.txt"
    - "**/*.xlsx"
    - "**/*.xls"
    - "**/*.mp3"
    - "**/*.wav"
    - "**/*.m4a"
    - "**/*.flac"
    - "**/*.ogg"
    - "**/*.aac"
    - "**/*.mp4"
    - "**/*.mov"
    - "**/*.mkv"
    - "**/*.webm"
    - "**/*.avi"
    - "**/*.m4v"
  exclude:
    - ".obsidian/**"
    - ".trash/**"
    - "**/.DS_Store"
    - "**/node_modules/**"                # npm dependencies — not user content
    # Add your own exclude patterns here
  # no_rename: path prefixes owned by external depositors (attachment capture,
  # sync tools). Files here are never renamed to carry @ID@ — the depositor
  # would re-deposit any file it no longer sees, creating duplicates. Doc IDs
  # for these paths live only in the registry, keyed by relative path.
  # no_rename:
  #   - "email-attachments/"
  #   - "quo-attachments/"

pdf:
  strategy: "text_then_ocr"
  ocr_page_limit: 200
  min_text_chars_before_ocr: 200

ocr:
  enabled: true
  provider: "gemini"                      # default for both PDF pages and images
  model: "gemini-2.0-flash"
  timeout: 120
  concurrency: 2
  # Optional: override just the image description provider
  # describe:
  #   provider: "ollama_vision"           # uses Ollama vision model for photos/screenshots
  #   model: "qwen3-vl:8b"
  #   base_url: "http://localhost:11434"

media:
  enabled: true
  provider: "openrouter"
  audio_model: "openai/whisper-1"
  fallback_audio_models:
    - "mistralai/voxtral-small-24b-2507"
    - "google/gemini-2.5-flash-lite"
  video_model: "qwen/qwen3.5-397b-a17b"
  max_file_size_mb: 50
  timeout: 300

embeddings:
  provider: "openrouter"                  # Qwen3-Embedding-8B via OpenRouter
  model: "qwen/qwen3-embedding-8b"
  batch_size: 64
  concurrency: 2
  # Alternatives: "baseten", "ollama" (local), "gemini" — see config.local.yaml.example

chunking:
  max_chars: 1800
  overlap: 200
  min_chars: 150
  semantic:
    enabled: false                        # disabled — requires local Ollama server
    # Enable with local Ollama: see config.local.yaml.example

communication_context:
  enabled: true
  window_before: 5
  window_after: 5
  max_time_window_minutes: 15
  same_channel_only: true
  include_batch: true

enrichment:
  enabled: true
  provider: "openrouter"                  # openrouter | litellm | ollama | baseten
  model: "openai/gpt-4.1-mini"
  # LiteLLM/Ollama Cloud V4 Pro example:
  # provider: "litellm"
  # model: "ollama-deepseek-v4-pro"
  # base_url: "http://host.docker.internal:4000/v1"
  # timeout: 600
  # temperature: 0.0
  max_input_chars: 20000                  # head+tail sampling: 10000 chars from start + 10000 from end
  max_output_tokens: 5000
  concurrency: 1                          # docs processed in parallel; 1=serial, 4-8 recommended on paid OpenRouter
  postprocess_enrichment: false           # optional deterministic repair pass; start with ["importance"] if enabled
  postprocess_rules: ["importance"]        # choices: importance, doc_type, key_facts
  trace_capture:
    enabled: false
    directory: ".evals/llm-traces"
  # Alternatives: "litellm", "baseten", "ollama" (local) — see config.local.yaml.example

search:
  mode: "hybrid"                          # parallel vector + keyword (BM25/FTS), fused with RRF
  vector_top_k: 50
  keyword_top_k: 50
  final_top_k: 10
  rrf_k: 60
  recency:
    half_life_days: 90
    weight: 0.3
  min_score_threshold: 0.0                # discard results below this score (0.0 = disabled; try 0.01-0.05)
  importance:
    field: "enr_importance"                # metadata field: LLM-generated or frontmatter-overridden (0.0-1.0)
    weight: 0.3                            # scaling: score *= (0.7 + 0.3 * importance); 0.0 = disabled
  reranker:
    enabled: true
    provider: "deepinfra"                 # Qwen3-Reranker-8B via DeepInfra (always-on, no cold start)
    model: "Qwen/Qwen3-Reranker-8B"
    timeout: 120

lancedb:
  table: "chunks"

logging:
  level: "WARNING"                        # DEBUG, INFO, WARNING, ERROR

event_hooks:
  enabled: false                          # emit document.indexed events after successful upserts
  hooks:
    # - name: "comm-data-store"
    #   type: "http"
    #   url: "http://comm-data-store-hooks:8090/hooks/doc-indexed"
    #   events: ["document.indexed"]
    #   timeout_seconds: 5
    #   secret_env: "COMM_DATA_STORE_HOOK_SECRET"

