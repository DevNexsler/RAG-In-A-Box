# Test config — mirrors the production OpenRouter / DeepInfra stack with
# test-only vault and index paths. Loaded by tests/test_integration.py.
#
# Required env vars for this integration suite's live tests:
#   OPENROUTER_API_KEY, DEEPINFRA_API_KEY
# OCR is deliberately disabled here. Dedicated real OCR/vision coverage lives
# in tests/test_litellm_ocr_live.py; it loads config.yaml and requires either
# LITELLM_API_KEY or LITELLM_MASTER_KEY in the environment.

vault_root: "./test_vault"
index_root: "./test_index"

scan:
  include:
    - "**/*.md"
    - "**/*.pdf"
    - "**/*.png"
    - "**/*.jpg"
    - "**/*.jpeg"
    - "**/*.docx"
    - "**/*.doc"
    - "**/*.pptx"
    - "**/*.rtf"
    - "**/*.epub"
    - "**/*.html"
    - "**/*.htm"
    - "**/*.csv"
    - "**/*.txt"
    - "**/*.xlsx"
    - "**/*.xls"
  exclude:
    - ".obsidian/**"
    - ".trash/**"
    - "**/.DS_Store"

pdf:
  strategy: "text_then_ocr"
  ocr_page_limit: 200
  min_text_chars_before_ocr: 200

ocr:
  enabled: false

embeddings:
  provider: "openrouter"
  model: "qwen/qwen3-embedding-8b"
  batch_size: 64
  concurrency: 2

chunking:
  max_chars: 1800
  overlap: 200
  min_chars: 150
  semantic:
    enabled: false

enrichment:
  enabled: true
  provider: "openrouter"
  model: "openai/gpt-4.1-mini"
  max_input_chars: 10000
  max_output_tokens: 768
  postprocess_enrichment: false
  postprocess_rules: ["importance"]
  trace_capture:
    enabled: false
    directory: ".evals/llm-traces"

search:
  mode: "hybrid"
  vector_top_k: 50
  keyword_top_k: 50
  final_top_k: 10
  rrf_k: 60
  recency:
    half_life_days: 90
    weight: 0.3
  reranker:
    enabled: true
    provider: "deepinfra"
    model: "Qwen/Qwen3-Reranker-8B"
    timeout: 120

lancedb:
  table: "chunks"

mcp:
  host: "127.0.0.1"
  port: 7788
