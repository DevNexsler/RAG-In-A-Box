# Test config — mirrors the production config stack (OpenRouter / DeepInfra /
# DeepSeek-OCR2) with test-only vault and index paths. Loaded by
# tests/test_integration.py.
#
# Required env vars for live tests:
#   OPENROUTER_API_KEY, DEEPINFRA_API_KEY
# DeepSeek-OCR2 OCR tests are skipped if the configured ocr.base_url is
# unreachable.

vault_root: "./test_vault"
index_root: "./test_index"

scan:
  include:
    - "**/*.md"
    - "**/*.pdf"
    - "**/*.png"
    - "**/*.jpg"
    - "**/*.jpeg"
    - "**/*.docx"
    - "**/*.doc"
    - "**/*.pptx"
    - "**/*.rtf"
    - "**/*.epub"
    - "**/*.html"
    - "**/*.htm"
    - "**/*.csv"
    - "**/*.txt"
    - "**/*.xlsx"
    - "**/*.xls"
  exclude:
    - ".obsidian/**"
    - ".trash/**"
    - "**/.DS_Store"

pdf:
  strategy: "text_then_ocr"
  ocr_page_limit: 200
  min_text_chars_before_ocr: 200

ocr:
  enabled: true
  provider: "deepseek_ocr2"
  base_url: "http://localhost:8790"
  timeout: 120
  concurrency: 1

embeddings:
  provider: "openrouter"
  model: "qwen/qwen3-embedding-8b"
  batch_size: 64
  concurrency: 2

chunking:
  max_chars: 1800
  overlap: 200
  min_chars: 150
  semantic:
    enabled: false

enrichment:
  enabled: true
  provider: "openrouter"
  model: "openai/gpt-4.1-mini"
  max_input_chars: 10000
  max_output_tokens: 768
  trace_capture:
    enabled: false
    directory: ".evals/llm-traces"

search:
  mode: "hybrid"
  vector_top_k: 50
  keyword_top_k: 50
  final_top_k: 10
  rrf_k: 60
  recency:
    half_life_days: 90
    weight: 0.3
  reranker:
    enabled: true
    provider: "deepinfra"
    model: "Qwen/Qwen3-Reranker-8B"
    timeout: 30

lancedb:
  table: "chunks"

mcp:
  host: "127.0.0.1"
  port: 7788
